// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Metric {
  id       String @id
  label    String
  value    String
  icon     String
  labelKey String
}

model Certificate {
  id          String @id
  title       String
  institution String
  year        String
  fileUrl     String
}

model Content {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
