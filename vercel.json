{
  "rewrites": [
    {
      "source": "/((?!assets/|cv/|certificates/|favicon.svg|og-image.jpg).*)" ,
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
